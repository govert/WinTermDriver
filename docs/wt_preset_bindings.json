{
  "_comment": "Expected WinTermDriver keybinding preset mirroring Windows Terminal defaults. Used by tests for the windows-terminal preset (wintermdriver-h35.3). Source: microsoft/terminal defaults.json + WT documentation.",
  "preset_name": "windows-terminal",
  "source_version": "Windows Terminal 1.21 (main branch, 2025)",
  "bindings": {
    "prefix": null,
    "prefix_timeout": null,
    "keys": {
      "Ctrl+Shift+T":    "new-tab",
      "Ctrl+Shift+W":    "close-pane",
      "Ctrl+Shift+C":    "copy",
      "Ctrl+Shift+V":    "paste",
      "Ctrl+Tab":        "next-tab",
      "Ctrl+Shift+Tab":  "prev-tab",
      "Ctrl+Shift+P":    "toggle-command-palette",
      "F11":             "toggle-fullscreen",
      "Alt+Shift+Plus":  "split-right",
      "Alt+Shift+Minus": "split-down",
      "Alt+Down":        "focus-pane-down",
      "Alt+Up":          "focus-pane-up",
      "Alt+Left":        "focus-pane-left",
      "Alt+Right":       "focus-pane-right",
      "Alt+Shift+Down":  "resize-pane-down",
      "Alt+Shift+Up":    "resize-pane-up",
      "Alt+Shift+Right": "resize-pane-right",
      "Alt+Shift+Left":  "resize-pane-left",
      "Alt+Shift+K":     "pass-through-next-key",
      "Ctrl+Insert":     "copy",
      "Shift+Insert":    "paste",
      "Ctrl+Shift+Up":       "scrollback-line-up",
      "Ctrl+Shift+Down":     "scrollback-line-down",
      "Ctrl+Shift+PageUp":   "scrollback-page-up",
      "Ctrl+Shift+PageDown": "scrollback-page-down",
      "Ctrl+Shift+Home":     "scrollback-top",
      "Ctrl+Shift+End":      "scrollback-bottom"
    },
    "chords": null
  },
  "wt_actions_omitted": [
    {
      "wt_command": "openNewTabDropdown",
      "wt_keys": ["ctrl+shift+space"],
      "reason": "WT-specific profile picker dropdown; no WTD equivalent (command palette uses Ctrl+Shift+P instead)"
    },
    {
      "wt_command": "openSettings (settingsUI)",
      "wt_keys": ["ctrl+,"],
      "reason": "No WTD settings UI in v1"
    },
    {
      "wt_command": "openSettings (settingsFile)",
      "wt_keys": ["ctrl+shift+,"],
      "reason": "No WTD in-app settings file editor"
    },
    {
      "wt_command": "openSettings (defaultsFile)",
      "wt_keys": ["ctrl+alt+,"],
      "reason": "No WTD defaults file editor"
    },
    {
      "wt_command": "find",
      "wt_keys": ["ctrl+shift+f"],
      "reason": "In-pane text search not in WTD v1 action catalog"
    },
    {
      "wt_command": "newWindow",
      "wt_keys": ["ctrl+shift+n"],
      "reason": "WTD new-window action exists but requires workspace context; omitted from preset"
    },
    {
      "wt_command": "duplicateTab",
      "wt_keys": ["ctrl+shift+d"],
      "reason": "No WTD duplicate-tab action"
    },
    {
      "wt_command": "switchToTab (0..7)",
      "wt_keys": ["ctrl+alt+1", "ctrl+alt+2", "ctrl+alt+3", "ctrl+alt+4", "ctrl+alt+5", "ctrl+alt+6", "ctrl+alt+7", "ctrl+alt+8"],
      "reason": "WTD goto-tab action exists but no profile-index-based launch"
    },
    {
      "wt_command": "switchToTab (last)",
      "wt_keys": ["ctrl+alt+9"],
      "reason": "WTD goto-tab has no 'last' semantic"
    },
    {
      "wt_command": "newTab (profile by index)",
      "wt_keys": ["ctrl+shift+1", "ctrl+shift+2", "ctrl+shift+3", "ctrl+shift+4", "ctrl+shift+5", "ctrl+shift+6", "ctrl+shift+7", "ctrl+shift+8", "ctrl+shift+9"],
      "reason": "WTD new-tab does not support profile-index parameter"
    },
    {
      "wt_command": "selectAll",
      "wt_keys": ["ctrl+shift+a"],
      "reason": "No WTD select-all action in v1"
    },
    {
      "wt_command": "markMode",
      "wt_keys": ["ctrl+shift+m"],
      "reason": "No WTD mark mode action in v1"
    },
    {
      "wt_command": "clearBuffer",
      "wt_keys": ["ctrl+shift+k"],
      "reason": "No WTD clear-buffer action in v1"
    },
    {
      "wt_command": "adjustFontSize (increase)",
      "wt_keys": ["ctrl+plus", "ctrl+numpad_plus"],
      "reason": "No WTD font size action; numpad keys not representable in WTD key specs"
    },
    {
      "wt_command": "adjustFontSize (decrease)",
      "wt_keys": ["ctrl+minus", "ctrl+numpad_minus"],
      "reason": "No WTD font size action; numpad keys not representable in WTD key specs"
    },
    {
      "wt_command": "resetFontSize",
      "wt_keys": ["ctrl+0", "ctrl+numpad_0"],
      "reason": "No WTD reset-font-size action; numpad keys not representable in WTD key specs"
    },
    {
      "wt_command": "closeWindow",
      "wt_keys": ["alt+f4"],
      "reason": "OS-level close; WTD close-window action requires workspace context"
    },
    {
      "wt_command": "toggleFullscreen (alt+enter)",
      "wt_keys": ["alt+enter"],
      "reason": "Secondary binding omitted; F11 is sufficient and matches WTD default"
    },
    {
      "wt_command": "openSystemMenu",
      "wt_keys": ["alt+space"],
      "reason": "OS system menu; not applicable to WTD"
    },
    {
      "wt_command": "quakeMode",
      "wt_keys": ["win+sc(41)"],
      "reason": "Quake/summon mode not in WTD v1; scan code keys not supported in WTD"
    },
    {
      "wt_command": "showSuggestions",
      "wt_keys": ["ctrl+shift+."],
      "reason": "Shell suggestion feature not in WTD v1"
    }
  ],
